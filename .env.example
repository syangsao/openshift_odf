# ODF Health Check — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# SSH jump host (leave empty for --direct mode)
SSH_HOST=
SSH_USER=
SSH_KEY=

# Kubeconfig path (on the jump host if using SSH, local if --direct)
KUBECONFIG=

# OpenShift namespace where ODF is installed
NAMESPACE=openshift-storage
